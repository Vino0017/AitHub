# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://skillhub:skillhub_dev@localhost:5432/skillhub?sslmode=disable

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
ADMIN_TOKEN=change-me-in-production
AUTO_MIGRATE=true
SEED_DATA=true

# ── OAuth (GitHub Device Flow) ────────────────────────────────────────────────
# Create a GitHub OAuth App: https://github.com/settings/developers
# Enable "Device Flow" in the app settings
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── OAuth (Google Device Flow) ────────────────────────────────────────────────
# Create credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── LLM / AI Review ──────────────────────────────────────────────────────────
# AI review is DISABLED if no API key is set, or if AI_REVIEW_ENABLED=false.
# When disabled, submissions with regex-detected secrets are still blocked.
# When enabled, submissions pass through Regex → LLM two-layer review.
AI_REVIEW_ENABLED=false

# Option 1: Anthropic (recommended)
ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Option 2: OpenAI or compatible (Ollama, Together, etc.)
# OPENAI_API_KEY=
# OPENAI_BASE_URL=http://localhost:11434
# OPENAI_MODEL=gpt-4o-mini

# Option 3: Generic (override all)
# Example: OpenRouter
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-or-v1-...
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL=google/gemma-4-31b-it

# ── SkillHub Agent Config (for installed agents) ─────────────────────────────
# SKILLHUB_TOKEN=sk_...
# SKILLHUB_AUTO_CONTRIBUTE=false    # true = auto-submit skills
# SKILLHUB_CONTRIBUTE=true          # false = disable contribution entirely
# SKILLHUB_DEFAULT_VISIBILITY=public
